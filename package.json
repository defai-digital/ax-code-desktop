{
  "name": "ax-code-desktop-monorepo",
  "version": "1.3.2",
  "description": "AX Code Desktop — AI coding assistant GUI, desktop runtime",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "keywords": [
    "ai",
    "coding",
    "ax-code",
    "cli"
  ],
  "author": "DEFAI Private Limited",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm run electron:dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter ./packages/web run build",
    "build:ui": "pnpm --filter ./packages/ui run build",
    "build:electron": "pnpm --filter ./packages/electron run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "pnpm -r run type-check",
    "type-check:web": "pnpm --filter ./packages/web run type-check",
    "type-check:ui": "pnpm --filter ./packages/ui run type-check",
    "type-check:electron": "pnpm --filter ./packages/electron run type-check",
    "lint": "pnpm -r run lint",
    "lint:web": "pnpm --filter ./packages/web run lint",
    "lint:ui": "pnpm --filter ./packages/ui run lint",
    "check:internal": "node scripts/check-internal-boundary.mjs",
    "check:boundary": "node scripts/check-boundary-imports.mjs",
    "check:endpoint-contracts": "node scripts/check-endpoint-contracts.mjs",
    "perf:report": "node scripts/ax-code-perf-report.mjs",
    "clean": "pnpm -r run clean",
    "changelog-card": "node scripts/changelog-card/generate.mjs",
    "postinstall": "patch-package",
    "electron:dev": "pnpm --filter ./packages/electron run dev",
    "electron:build": "pnpm --filter ./packages/electron run build",
    "docs:validate": "node scripts/docs/validate-docs.mjs",
    "doctor": "node scripts/react-doctor.mjs",
    "icons:sprite": "node scripts/generate-file-type-sprite.mjs",
    "icons:generate": "node scripts/generate-icon-sprite.mjs",
    "themes:port:ax-code": "tsx scripts/port-ax-code-theme.ts",
    "version:bump": "node scripts/bump-version.mjs",
    "release:prepare": "pnpm run check:internal && pnpm run check:boundary && pnpm run check:endpoint-contracts && pnpm run build && pnpm run type-check && pnpm run lint",
    "sign:keygen": "./scripts/minisign-keygen.sh",
    "release:sign": "./scripts/minisign-artifacts.sh",
    "publish:github": "./scripts/publish-github-release.sh",
    "release:test": "./scripts/test-release-build.sh",
    "release:test:arm": "./scripts/test-release-build.sh aarch64"
  },
  "dependencies": {
    "@ax-code/sdk": "file:./vendor/ax-code-sdk",
    "@base-ui/react": "^1.4.0",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "6.12.2",
    "@codemirror/lint": "^6.9.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "6.39.13",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.1.1",
    "@heroui/scroll-shadow": "^2.3.18",
    "@heroui/system": "^2.4.23",
    "@heroui/theme": "^2.4.23",
    "@ibm/plex": "^6.4.1",
    "@lezer/highlight": "^1.2.3",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/react-syntax-highlighter": "^15.5.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "express": "^5.1.0",
    "ghostty-web": "0.3.0",
    "http-proxy-middleware": "^3.0.5",
    "next-themes": "^0.4.6",
    "node-pty": "1.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.6",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.28.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "yaml": "^2.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  },
  "pnpm": {
    "overrides": {
      "@codemirror/language": "6.12.2",
      "@codemirror/view": "6.39.13",
      "@radix-ui/react-primitive": "2.1.4",
      "node-gyp": "^11"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^25.0.1",
    "node-addon-api": "7.1.1",
    "nodemon": "^3.1.7",
    "patch-package": "^8.0.0",
    "@remixicon/react": "^4.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.3.8",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^4.1.4"
  }
}
